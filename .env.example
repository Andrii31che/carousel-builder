# Copy to .env (local) or set in Railway → Variables

# === Required for generate.js ===

# Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot token (create via @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Your Telegram user id (get via @userinfobot)
TELEGRAM_CHAT_ID=123456789

# === Optional ===

# Override the Builder API URL (default = prod Railway)
# BUILDER_API_URL=https://carousel-builder-production.up.railway.app/api/render

# Claude model (default = claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Dry run: skip Telegram send and don't mark topic as posted
# DRY_RUN=1
